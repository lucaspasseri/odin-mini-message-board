<%
const messages = data.messages ?? [];
const messageContainerClass =
  messages.length === 0 ? "message-container empty" : "message-container";

const getMessageId = (message) => {
	return `message-${message.id}`
}
%>

<!doctype html>
<html lang="en">
	<%- include('partials/head') %>
	<body>
		<%- include('partials/header') %>
		<main>
			<div class='<%= messageContainerClass %>' >
				<% if(data.messages.length === 0 ) { %>
					<p>( No message found )</p>
				<% } else { %>
					<ul>
						<% data.messages?.forEach(message => { %>
						
								<li class="card" id="<%= getMessageId(message) %>">
									<p>	<%= message?.text %></p>
									<div>
										<div>
											<p>	<%= message?.user %> - <%= message?.added %></p>
										</div>
										<a href="/message/<%= message.id %>" >Open</a>
									</div>
								</li>
					
						<% }) %>
					</ul>
				<% } %>
			</div>

			<%- include('partials/newMessageForm') %>
		</main>
	</body>
</html>
